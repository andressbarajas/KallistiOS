+#define OPTION_NO_DMA_VIF (OPTION_MD_BASE + 2)
+  { "no-dma-vif", no_argument, NULL, OPTION_NO_DMA_VIF },
+#define OPTION_MABI       (OPTION_MD_BASE + 3)
+  { "mabi", required_argument, NULL, OPTION_MABI },

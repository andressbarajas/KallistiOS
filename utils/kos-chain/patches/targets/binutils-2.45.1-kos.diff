+ATTRIBUTE_UNUSED static long
+parse_dma_addr (const dvp_opcode *opcode ATTRIBUTE_UNUSED,
+                const dvp_operand *operand ATTRIBUTE_UNUSED,
+                int mods ATTRIBUTE_UNUSED, char **pstr ATTRIBUTE_UNUSED,
